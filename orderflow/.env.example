NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgres://orderflow:orderflow@localhost:5432/orderflow

# Redis (used for sessions — not wired by default in Phase 0)
REDIS_URL=redis://localhost:6379

# Session
SESSION_SECRET=change-me-in-production

# Email (nodemailer — set to "log" in dev to avoid real sends)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@orderflow.com
